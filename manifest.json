{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.0.0",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "seafile-filelink@datamate.org",
      "strict_min_version": "128.0"
    }
  },
  "cloud_file": {
    "name": "__MSG_serviceName__",
    "management_url": "management/management.html",
    "reuse_uploads": false
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "64": "icons/icon-64.png"
  },
  "background": {
    "scripts": ["api/seafile.js", "background.js"]
  },
  "permissions": ["storage", "messagesRead"],
  "host_permissions": ["<all_urls>"],
  "message_display_action": {
    "default_popup": "save-attachments/popup.html",
    "default_title": "__MSG_saveToSeafile__",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
